{
  "name": "jmap-mcp",
  "version": "0.6.2",
  "description": "MCP server for JMAP email management",
  "author": {
    "name": "Wyatt Johnson"
  },
  "userConfig": {
    "jmap_session_url": {
      "title": "JMAP Session URL",
      "type": "string",
      "description": "JMAP server session URL (e.g., https://api.fastmail.com/jmap/session)",
      "sensitive": false
    },
    "jmap_bearer_token": {
      "title": "JMAP Bearer Token",
      "type": "string",
      "description": "Bearer token for JMAP authentication",
      "sensitive": true
    },
    "jmap_account_id": {
      "title": "JMAP Account ID",
      "type": "string",
      "description": "JMAP account ID (optional, auto-detected if not provided)",
      "sensitive": false
    }
  },
  "mcpServers": {
    "jmap": {
      "command": "deno",
      "args": [
        "run",
        "--allow-env",
        "--allow-net",
        "jsr:@wyattjoh/jmap-mcp@0.6.2"
      ],
      "env": {
        "JMAP_SESSION_URL": "${user_config.jmap_session_url}",
        "JMAP_BEARER_TOKEN": "${user_config.jmap_bearer_token}",
        "JMAP_ACCOUNT_ID": "${user_config.jmap_account_id}"
      }
    }
  }
}
